// in this we have to find the longest string in the array such that every prefix of the string is also present in the array
// we can do it in a naive way by checking for every string in the array and then checking for all its prefixes in the array and then finding the longest string but it will take O(n^2) time complexity
// we can do it in a better way by using trie data structure we can insert all the strings in the array in the trie and then for each string we can check for all its prefixes in the trie and then find the longest string
//if all its letter have endofvalue true then we can consider that string as a candidate for longest string and then we can compare it with the longest string found so far and update the longest string if the current string is longer than the longest string found so far

class Solution {
    public String longestString(String[] words) {
         Trie trie=new Trie();
        for(int i=0;i<words.length;i++){    
            insert(trie,words[i]);
        }
        String longest="";
        for(int i=0;i<words.length;i++){
            if(startsWith(trie,words[i])){  //here weee are checking for all the prefixes of the current string if they are present in the trie or not if they are present then we can consider that string as a candidate for longest string and then we can compare it with the longest string found so far and update the longest string if the current string is longer than the longest string found so far
                if(words[i].length()>longest.length() || (words[i].length()==longest.length() && words[i].compareTo(longest)<0)){
                    longest=words[i];
                }
            }
        }
        return longest;
    }
    public void insert(Trie trie,String word) {

        Trie node=trie;
        for(char c:word.toCharArray()){
            int index=c-'a';
            if(node.children[index]==null){
                node.children[index]=new Trie();
            }
            node=node.children[index];
        }
        node.isEndOfWord=true;
    }
    public boolean startsWith(Trie trie,String prefix) {
        Trie node=trie;
        for(char c:prefix.toCharArray()){
            int index=c-'a';
            if(node.children[index]==null){
                return false;
            }
            node=node.children[index];
            if(!node.isEndOfWord){ //here we are checking for every element as end of word if any element is not end of word then we can return false because we are checking for all the prefixes of the current string if they are present in the trie or not if they are present then we can consider that string as a candidate for longest string and then we can compare it with the longest string found so far and update the longest string if the current string is longer than the longest string found so far
                return false;
            }
        }
        return true; 
    }
    static class Trie{
        Trie[] children=new Trie[26];
        boolean isEndOfWord;
        Trie(){
            Arrays.fill(children, null);
            isEndOfWord=false;
        }
    }
}
